---
// Chapter 06: The Signal — Contact
---

<section class="contact chapter-section" id="contact">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-left">
        <span class="chapter-num reveal reveal-scale">CH.07</span>
        <h2 class="section-heading reveal reveal-up delay-1">
          Send a <em class="serif">Signal</em>
        </h2>
        <p class="contact-desc reveal reveal-up delay-2">
          Building products where complexity, automation, and scale intersect?<br/>
          <strong>Let's talk.</strong>
        </p>

        <div class="contact-links reveal reveal-up delay-3">
          <a href="mailto:akshayanmohandass@gmail.com" class="cl-row">
            <span class="cl-label mono">EMAIL</span>
            <span class="cl-val">akshayanmohandass@gmail.com →</span>
          </a>
          <a href="https://www.linkedin.com/in/akshayan-mohandass-" target="_blank" rel="noopener noreferrer" class="cl-row">
            <span class="cl-label mono">LINKEDIN</span>
            <span class="cl-val">Connect →</span>
          </a>
          <a href="https://drive.google.com/uc?export=download&id=1JxVQMcN5wL2YpTLA3L74jXCL82JdWJon" target="_blank" rel="noopener noreferrer" class="cl-row">
            <span class="cl-label mono">RESUME</span>
            <span class="cl-val">Download PDF →</span>
          </a>
        </div>
      </div>

      <div class="contact-right reveal reveal-right delay-3">
        <form class="contact-form" id="contact-form">
          <div class="cf-header">
            <span>✦ DROP A MESSAGE</span>
          </div>
          <div class="cf-body">
            <div class="cf-group">
              <label class="mono" for="c-name">NAME</label>
              <input type="text" id="c-name" name="name" placeholder="Your name" required />
            </div>
            <div class="cf-group">
              <label class="mono" for="c-email">EMAIL</label>
              <input type="email" id="c-email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="cf-group">
              <label class="mono" for="c-msg">MESSAGE</label>
              <textarea id="c-msg" name="message" rows="4" placeholder="Tell me about your project..." required></textarea>
            </div>
            <button type="submit" class="cf-submit" id="cf-btn">
              SEND IT ↗
            </button>
            <p class="cf-feedback" id="cf-feedback" aria-live="polite"></p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .contact-desc {
    font-size: var(--text-base);
    color: var(--dark-grey);
    line-height: 1.8;
    margin-bottom: var(--space-6);
  }

  .contact-desc strong { color: var(--black); font-weight: 900; font-size: var(--text-lg); }

  /* Contact links — neobrutalism list */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: var(--border-brutal);
    box-shadow: var(--shadow-sm);
  }

  .cl-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 20px;
    border-bottom: var(--border-thick);
    transition: all 0.15s ease;
    background: var(--white);
  }

  .cl-row:last-child { border-bottom: none; }

  .cl-row:hover {
    background: var(--primary);
    padding-left: 28px;
  }

  .cl-label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--grey);
  }

  .cl-row:hover .cl-label { color: var(--black); }

  .cl-val {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text);
  }

  /* Form — neobrutalism card */
  .contact-form {
    border: var(--border-brutal);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    transition: all 0.15s ease;
  }

  .contact-form:hover {
    box-shadow: var(--shadow-sm);
  }

  .cf-header {
    padding: 14px 20px;
    background: var(--secondary);
    border-bottom: var(--border-thick);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
  }

  .cf-body {
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: var(--white);
  }

  .cf-group { display: flex; flex-direction: column; gap: 6px; }

  .cf-group label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--grey);
  }

  .cf-group input,
  .cf-group textarea {
    padding: 12px 14px;
    border: var(--border-thick);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background: var(--white);
    color: var(--text);
    outline: none;
    resize: vertical;
    transition: all 0.2s ease;
  }

  .cf-group input:focus,
  .cf-group textarea:focus {
    background: var(--primary);
    box-shadow: var(--shadow-sm);
    transform: translate(-2px, -2px);
  }

  .cf-submit {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 16px 28px;
    background: var(--primary);
    color: var(--black);
    border: var(--border-thick);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .cf-submit:hover {
    box-shadow: none;
    transform: translate(4px, 4px);
    background: var(--secondary);
    color: var(--white);
  }

  .cf-submit:active {
    transform: translate(6px, 6px);
  }

  .cf-feedback {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 1px;
    min-height: 20px;
    text-align: center;
  }

  .cf-feedback.success { color: #1a8a3c; }
  .cf-feedback.error   { color: #c0392b; }

  .cf-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 1024px) {
    .contact-layout { grid-template-columns: 1fr; gap: 32px; }
  }

  @media (max-width: 480px) {
    .contact-layout {
      gap: 24px;
    }

    .cl-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      padding: 14px 16px;
    }

    .cl-row:hover {
      padding-left: 20px;
    }

    .cl-val {
      font-size: var(--text-xs);
      word-break: break-all;
    }

    .cf-body {
      padding: 20px 16px;
    }

    .cf-submit {
      padding: 14px 20px;
      font-size: 12px;
    }

    .contact-desc {
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  import emailjs from '@emailjs/browser';

  const SERVICE_ID  = 'service_a8yhlt9';
  const TEMPLATE_ID = 'template_q32vjui';
  const PUBLIC_KEY  = '_wY8Z_EeqK9LiJ2lf';

  emailjs.init(PUBLIC_KEY);

  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const btn      = document.getElementById('cf-btn') as HTMLButtonElement;
  const feedback = document.getElementById('cf-feedback') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = 'SENDING...';
    feedback.textContent = '';
    feedback.className = 'cf-feedback';

    try {
      await emailjs.sendForm(SERVICE_ID, TEMPLATE_ID, form);
      feedback.textContent = '✦ MESSAGE SENT. I\'ll get back to you soon.';
      feedback.className = 'cf-feedback success';
      form.reset();
    } catch {
      feedback.textContent = '✦ SOMETHING WENT WRONG. Try emailing me directly.';
      feedback.className = 'cf-feedback error';
    } finally {
      btn.disabled = false;
      btn.textContent = 'SEND IT ↗';
    }
  });
</script>
