---
// Chapter 03: The Journey — Refined Minimal Premium (Accessible/Readable)
const jobs = [
  {
    i: 0,
    num: "01",
    co: "Mondee",
    role: "UX Designer & Content Strategist",
    product: "Miraee",
    period: "2026 — Present",
    tag: "Current",
    accent: "#FDC800",
    accentTint: "rgba(253,200,0,0.08)",
    tagText: "#000000",
    desc: "Shaping an AI-native enterprise product from the ground up — owning both the user experience and the content strategy that defines how the system thinks, speaks, and guides its users.",
    cols: [],
  },
  {
    i: 1,
    num: "02",
    co: "Kodecopter",
    role: "Product Designer",
    product: "AI Systems & Full Stack",
    period: "2024 — 2025",
    tag: "",
    accent: "#432DD7",
    accentTint: "rgba(67,45,215,0.06)",
    tagText: "#ffffff",
    desc: "Designed intelligent product systems end-to-end in a fast-moving AI startup, from architecture tooling to financial dashboards.",
    cols: [
      {
        label: "What I built",
        items: ["KodeEngine — AI generator", "FIN AI — Financial dashboards", "Input-output frameworks", "Documentation-first UI"],
      },
      {
        label: "Outcome",
        items: ["4 products shipped in 12 months", "Full design ownership", "Zero-to-launch execution"],
      },
    ],
  },
  {
    i: 2,
    num: "03",
    co: "Bloom Majestic",
    role: "UI/UX Designer",
    product: "Inniyal — Mental Wellness",
    period: "2022 — 2023",
    tag: "",
    accent: "#D97706",
    accentTint: "rgba(217,119,6,0.08)",
    tagText: "#ffffff",
    desc: "Crafted emotionally-sensitive mobile experiences, prioritising calm, uncluttered interactions that reduce cognitive friction.",
    cols: [
      {
        label: "What I built",
        items: ["Intuitive onboarding", "Cognitive-load system", "Emotional design language"],
      },
      {
        label: "Outcome",
        items: ["4.8★ App Store rating", "Featured in wellness category", "Accessibility benchmarks met"],
      },
    ],
  },
  {
    i: 3,
    num: "04",
    co: "Aakam 360",
    role: "UI/UX Intern",
    product: "PregTrack — MSME Approved",
    period: "2023 — 2024",
    tag: "",
    accent: "#16A34A",
    accentTint: "rgba(22,163,74,0.08)",
    tagText: "#ffffff",
    desc: "Structured user flows and supported frontend implementation for a pregnancy tracking app, a government-approved MSME product.",
    cols: [
      {
        label: "What I built",
        items: ["End-to-end user flows", "Frontend support", "MSME-compliant design"],
      },
      {
        label: "Outcome",
        items: ["MSME certified & launched", "First shipped product", "Cross-functional execution"],
      },
    ],
  },
];
---

<section class="exp chapter-section" id="experience">
  <div class="container">

    <!-- Header -->
    <div class="exp-header reveal reveal-up">
      <span class="chapter-num">CH.03</span>
      <h2 class="exp-title">The <em class="serif">Journey</em></h2>
    </div>

    <!-- Column labels -->
    <div class="exp-labels reveal reveal-up delay-1">
      <span class="el-num">#</span>
      <span class="el-co">Company</span>
      <span class="el-role">Role</span>
      <span class="el-period">Timeline</span>
      <span class="el-icon"></span>
    </div>

    <!-- Experience rows -->
    <div class="exp-rows reveal reveal-up delay-2">
      {jobs.map((j) => (
        <div
          class={`exp-item ${j.i === 0 ? "is-open" : ""}`}
          data-item={j.i}
          style={`--accent:${j.accent}; --tint:${j.accentTint}`}
        >
          <!-- Trigger row -->
          <button class="exp-trigger">
            <span class="et-num">{j.num}</span>
            <span class="et-co">
              {j.co}
              {j.tag && <span class="et-tag" style={`--tag-bg: ${j.accent}; color: ${j.tagText}`}>{j.tag}</span>}
            </span>
            <span class="et-role">{j.role}</span>
            <span class="et-period">{j.period}</span>
            <span class="et-icon">
              <!-- Plus/Minus Icon -->
              <span class="icon-line horiz"></span>
              <span class="icon-line vert"></span>
            </span>
          </button>

          <!-- Expanded body -->
          <div class="exp-body">
            <div class="eb-inner">
              <div class="eb-content-wrap">
                <!-- Product label -->
                <h4 class="eb-product">{j.product}</h4>

                <!-- Description + columns -->
                <div class={`eb-grid ${j.cols.length === 0 ? "eb-grid--full" : ""}`}>
                  <p class="eb-desc">{j.desc}</p>

                  {j.cols.length > 0 && (
                    <div class="eb-cols-wrapper">
                      {j.cols.map((col) => (
                        <div class="eb-col">
                          <p class="eb-col-label">{col.label}</p>
                          <ul class="eb-col-list">
                            {col.items.map((item) => (
                              <li>{item}</li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Featured project -->
    <!-- <div class="featured reveal reveal-up delay-3">
      <div class="feat-badge">★ Featured Project</div>
      <div class="featured-inner">
        <div class="feat-left">
          <h3 class="feat-name">Fees Management Automation System</h3>
          <p class="feat-desc">Built a scalable financial workflow using Flutter + Provider — role-based authority, real-time reporting, automated late-fee logic. Designed and developed end-to-end.</p>
          <div class="feat-chips">
            <span>Flutter</span><span>Provider</span><span>Finance</span><span>Role-Based</span><span>Admin</span>
          </div>
        </div>
        <div class="feat-right">
          <div class="feat-stat-card">
            <span class="feat-metric">100%</span>
            <span class="feat-metric-sub">Autonomy / Ownership</span>
          </div>
        </div>
      </div>
    </div> -->

  </div>
</section>

<style>
  /* ── Section ── */
  .exp-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }

  .exp-title {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--text);
    margin: 0;
  }

  /* ── Column labels ── */
  .exp-labels {
    display: grid;
    grid-template-columns: 48px 1.5fr 1fr 140px 48px;
    gap: 20px;
    padding: 0 16px 16px 16px;
    border-bottom: 3px solid var(--black);
    margin-bottom: 0;
  }

  .exp-labels span {
    font-family: var(--font-mono);
    font-size: 13px; /* Increased legibility */
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text); /* Increased contrast */
  }

  .el-num { color: var(--dark-grey); } /* Slightly lighter for the # sign if needed */
  .el-icon { text-align: right; }

  /* ── Rows wrapper ── */
  .exp-rows {
    margin-bottom: 64px;
    border-bottom: 3px solid var(--black);
  }

  /* ── Single item ── */
  .exp-item {
    border-bottom: 1px solid rgba(28, 41, 60, 0.15);
    background: transparent;
    transition: background 0.3s ease;
  }

  .exp-item:last-child {
    border-bottom: none;
  }

  /* ── Trigger ── */
  .exp-trigger {
    width: 100%;
    display: grid;
    grid-template-columns: 48px 1.5fr 1fr 140px 48px;
    gap: 20px;
    align-items: center;
    padding: 28px 16px;
    background: none;
    border: none;
    border-left: 4px solid transparent;
    cursor: pointer;
    text-align: left;
    transition: all 0.25s ease;
  }

  .exp-trigger:hover {
    background: var(--cream);
  }

  .exp-item.is-open .exp-trigger {
    background: var(--tint);
    border-left-color: var(--accent);
  }

  .et-num {
    font-family: var(--font-mono);
    font-size: 14px; /* Increased legibility */
    font-weight: 700;
    color: var(--dark-grey); /* Better contrast than light grey */
    letter-spacing: 1px;
    transition: color 0.3s ease;
  }
  .exp-item.is-open .et-num { color: var(--accent); font-weight: 900; }

  .et-co {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: clamp(1.4rem, 2.8vw, 2rem); /* Slightly larger */
    font-weight: 900;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .exp-item.is-open .et-co { color: var(--black); }

  .et-tag {
    font-family: var(--font-mono);
    font-size: 10px; /* Increased */
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 10px;
    background: var(--tag-bg);
    /* Color set inline to ensure high contrast based on background */
    border: 1.5px solid var(--black);
    line-height: 1;
    display: inline-block;
    transform: translateY(-2px);
  }

  .et-role {
    font-family: var(--font-sans);
    font-size: 16px; /* Increased legibility */
    color: var(--text); /* Better contrast */
    font-weight: 600;
  }

  .et-period {
    font-family: var(--font-mono);
    font-size: 14px; /* Increased legibility */
    color: var(--text); /* Better contrast */
    font-weight: 600;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .et-icon {
    position: relative;
    width: 20px;
    height: 20px;
    margin-left: auto;
  }

  .icon-line {
    position: absolute;
    background: var(--black);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s ease;
  }

  .icon-line.horiz {
    width: 20px;
    height: 3px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .icon-line.vert {
    width: 3px;
    height: 20px;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .exp-item.is-open .icon-line.vert {
    transform: translateX(-50%) rotate(90deg);
  }
  .exp-item.is-open .icon-line {
    background: var(--accent);
  }

  /* ── Expanded body ── */
  .exp-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .exp-item.is-open .exp-body {
    grid-template-rows: 1fr;
  }

  .eb-inner {
    overflow: hidden;
  }

  .eb-content-wrap {
    padding: 16px 24px 36px 72px; /* aligns with Company column */
    border-left: 4px solid var(--accent);
    background: var(--tint);
  }

  .eb-product {
    font-family: var(--font-sans);
    font-size: 1.35rem; /* Increased legibility */
    font-weight: 800;
    color: var(--black);
    margin: 0 0 16px 0;
    letter-spacing: -0.01em;
  }

  .eb-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    align-items: start;
  }

  .eb-grid--full {
    grid-template-columns: 1fr;
  }

  .eb-desc {
    font-family: var(--font-sans);
    font-size: var(--text-base); /* Increased legibility */
    color: var(--text); /* Best contrast */
    line-height: 1.8;
    margin: 0;
  }

  .eb-cols-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .eb-col-label {
    font-family: var(--font-mono);
    font-size: 13px; /* Increased legibility */
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 16px;
    display: inline-block;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 4px;
  }

  .eb-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .eb-col-list li {
    font-family: var(--font-sans);
    font-size: var(--text-base); /* Increased legibility */
    color: var(--text); /* Best contrast */
    line-height: 1.5;
    position: relative;
    padding-left: 16px;
  }

  .eb-col-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border: 1px solid var(--black);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    /* Keep the grid layout on tablet, but adjust spacing */
    .exp-labels {
      grid-template-columns: 40px 1.5fr 1fr 100px 40px;
    }
    .exp-trigger {
      grid-template-columns: 40px 1.5fr 1fr 100px 40px;
      padding: 24px 16px;
    }
    .eb-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    /* Full mobile layout change: Stack elements gracefully to ensure 100% visibility */
    .exp-labels { display: none; }

    .exp-trigger {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px; /* spacing between lines */
      padding: 24px 16px;
      position: relative;
    }

    .et-num {
      width: 32px; /* Fixed width for alignment */
    }

    .et-co {
      flex: 1; 
      font-size: 1.6rem; /* Good size for mobile headers */
    }

    .et-icon {
      position: absolute;
      right: 16px;
      top: 24px;
    }

    .et-role {
      flex-basis: 100%;
      padding-left: 44px; /* aligned visually with company name */
      font-size: 16px;
      color: var(--text);
      margin-top: 4px;
    }

    .et-period {
      flex-basis: 100%;
      padding-left: 44px;
      font-size: 14px;
      color: var(--dark-grey); /* distinguish slightly from role */
      margin-top: -4px;
    }

    .eb-content-wrap {
      padding: 0 16px 28px 16px;
      margin-left: 16px; /* align with accordion elements */
    }

    .eb-cols-wrapper {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    
    .featured {
      padding: 40px 24px;
    }

    .feat-badge {
      left: 20px;
    }
  }

  @media (max-width: 480px) {
    .exp-header {
      gap: 12px;
      margin-bottom: 36px;
    }

    .exp-title {
      font-size: clamp(2rem, 8vw, 2.8rem);
    }

    .exp-trigger {
      padding: 20px 12px;
      gap: 8px;
    }

    .et-num {
      width: 26px;
      font-size: 12px;
    }

    .et-co {
      font-size: 1.3rem;
    }

    .et-role {
      font-size: 14px;
      padding-left: 34px;
    }

    .et-period {
      font-size: 12px;
      padding-left: 34px;
    }

    .et-icon {
      right: 12px;
      top: 20px;
    }

    .eb-content-wrap {
      padding: 0 12px 24px 12px;
      margin-left: 0;
    }

    .eb-product {
      font-size: 1.15rem;
    }

    .eb-grid {
      gap: 20px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.exp-item').forEach((item) => {
    item.querySelector('.exp-trigger')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');

      // Close all
      document.querySelectorAll('.exp-item').forEach(el => el.classList.remove('is-open'));

      // Toggle
      if (!isOpen) item.classList.add('is-open');
    });
  });
</script>
