---
// Chapter 03: The Journey — Experience
const jobs = [
  {
    co: "MONDEE",
    role: "Product Designer — Miraee",
    sub: "Enterprise Travel Intelligence",
    desc: "AI-native corporate travel platform. Reduced operational friction across booking, approvals, and expense management.",
    points: ["Multi-role dashboards", "Booking → Approval → Expense lifecycle", "Executive spending intelligence", "Authority-based UI architecture"],
    tag: "CURRENT",
    accent: "var(--neon-green)",
  },
  {
    co: "KODECOPTER",
    role: "Product Designer",
    sub: "AI Systems & Full Stack",
    desc: "Built intelligent product systems from concept to execution in a fast-moving startup.",
    points: ["KodeEngine — AI architecture generator", "FIN AI — Financial tools", "AI input-output clarity frameworks", "Documentation-first interfaces"],
    tag: "",
    accent: "var(--neon-pink)",
  },
  {
    co: "BLOOM MAJESTIC",
    role: "UI/UX Designer — Inniyal",
    sub: "Mental Wellness Platform",
    desc: "Designed emotionally-sensitive mobile experiences focused on clarity and accessibility.",
    points: ["Intuitive onboarding", "Reduced cognitive load", "Emotional design consistency"],
    tag: "",
    accent: "var(--neon-yellow)",
  },
  {
    co: "AAKAM 360",
    role: "UI/UX Intern — PregTrack",
    sub: "MSME Approved Product",
    desc: "Structured user flows and supported frontend implementation for a pregnancy tracking app.",
    points: [],
    tag: "",
    accent: "var(--neon-blue)",
  },
];
---

<section class="exp chapter-section" id="experience">
  <div class="container">
    <span class="chapter-num reveal reveal-scale">CH.03</span>
    <h2 class="section-heading reveal reveal-up delay-1">
      The <em class="serif">Journey</em>
    </h2>

    <div class="exp-stack">
      {jobs.map((j, i) => (
        <div class={`exp-card reveal reveal-up delay-${(i % 3) + 1}`} style={`--card-accent: ${j.accent}`} data-depth="1">
          <div class="ec-top">
            <span class="ec-co">{j.co}</span>
            {j.tag && <span class="ec-tag">{j.tag}</span>}
          </div>
          <h3 class="ec-role">{j.role}</h3>
          <p class="ec-sub">{j.sub}</p>
          <p class="ec-desc">{j.desc}</p>
          {j.points.length > 0 && (
            <ul class="ec-points">
              {j.points.map(p => <li>{p}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>

    <!-- System Highlight -->
    <div class="sys-highlight reveal reveal-up delay-2" data-depth="1.5">
      <div class="sh-badge">★ SYSTEM HIGHLIGHT</div>
      <div class="sh-body">
        <h3>Fees Management Automation System</h3>
        <p>Built a scalable financial workflow system using Flutter + Provider. Role-based authority, real-time reporting, automated late logic.</p>
        <div class="sh-tags">
          <span>Flutter</span><span>Provider</span><span>Finance</span><span>Role-Based</span><span>Admin</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .exp-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
    margin-bottom: 40px;
  }

  .exp-card {
    border: var(--border-brutal);
    background: var(--white);
    box-shadow: var(--shadow-md);
    padding: 0;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    overflow: hidden;
  }

  .exp-card:hover {
    box-shadow: none;
    transform: translate(6px, 6px);
  }

  .ec-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    border-bottom: var(--border-thick);
    background: var(--card-accent);
  }

  .ec-co {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .ec-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 3px 10px;
    background: var(--black);
    color: var(--neon-green);
    border: 2px solid var(--black);
  }

  .ec-role {
    font-size: 1.05rem;
    font-weight: 700;
    padding: 16px 20px 4px;
  }

  .ec-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--grey);
    padding: 0 20px;
    letter-spacing: 1px;
  }

  .ec-desc {
    font-size: 0.9rem;
    color: var(--dark-grey);
    line-height: 1.6;
    padding: 12px 20px;
  }

  .ec-points {
    list-style: none;
    padding: 0 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ec-points li {
    font-size: 0.82rem;
    color: var(--dark-grey);
    padding-left: 16px;
    position: relative;
  }

  .ec-points li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--neon-pink);
    font-weight: 700;
  }

  /* System Highlight */
  .sys-highlight {
    border: var(--border-brutal);
    box-shadow: var(--shadow-pink);
    overflow: hidden;
    transition: all 0.15s ease;
  }

  .sys-highlight:hover {
    box-shadow: none;
    transform: translate(6px, 6px);
  }

  .sh-badge {
    padding: 12px 20px;
    background: var(--neon-pink);
    border-bottom: var(--border-thick);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--white);
  }

  .sh-body {
    padding: 24px 20px;
  }

  .sh-body h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .sh-body p {
    font-size: 0.9rem;
    color: var(--dark-grey);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .sh-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sh-tags span {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border: 2px solid var(--black);
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.15s ease;
  }

  .sh-tags span:hover {
    background: var(--black);
    color: var(--neon-green);
  }

  @media (max-width: 768px) {
    .exp-stack { grid-template-columns: 1fr; }
  }
</style>
