---
// Hero — Bazil-inspired layout with Neobrutalism theme
---

<section class="hero" id="hero">
  <div class="hero-content">
    <!-- Intro line -->
    <p class="hero-intro anim-fade anim-d1">
      👋, my name is <strong>Akshayan</strong> and I am a
    </p>

    <!-- Massive title block -->
    <div class="hero-title-wrap">
      <h1 class="hero-title-solid anim-fade anim-d2">
        <span>Product</span>
        <span>Designer</span>
      </h1>

      <!-- Photo overlapping the text from center -->
      <div class="hero-photo anim-fade anim-d3">
        <div class="photo-frame">
          <img src="/hero-portrait.png" alt="Akshayan Mohandass" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="photo-placeholder">
            <span class="photo-initials">AM</span>
          </div>
        </div>
        <div class="photo-sticker">DESIGNER ✦</div>
      </div>

      <h1 class="hero-title-stroke anim-fade anim-d4">
        <span>& Systems</span>
        <span>Thinker</span>
      </h1>
    </div>



    <!-- CTAs -->
    <div class="hero-ctas anim-fade anim-d6">
      <a href="#experience" class="cta-btn cta-primary">
        <span>View my work</span>
        <span class="cta-arrow">↗</span>
      </a>
      <a href="#contact" class="cta-btn cta-secondary">
        <span>Get in touch</span>
      </a>
    </div>
  </div>

  <!-- Marquee -->
  <div class="marquee-strip">
    <div class="marquee-inner">
      PRODUCT DESIGNER ✦ SYSTEMS THINKER ✦ AI-NATIVE ✦ UX ARCHITECT ✦ ENTERPRISE ✦ PRODUCT DESIGNER ✦ SYSTEMS THINKER ✦ AI-NATIVE ✦ UX ARCHITECT ✦ ENTERPRISE ✦ PRODUCT DESIGNER ✦ SYSTEMS THINKER ✦ AI-NATIVE ✦&nbsp;
    </div>
  </div>
</section>

<style>
  /* ---- ENTRY ANIMATIONS (no JS required) ---- */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim-fade {
    animation: heroFadeUp 0.7s ease forwards;
    opacity: 0;
  }

  .anim-d1 { animation-delay: 0.1s; }
  .anim-d2 { animation-delay: 0.25s; }
  .anim-d3 { animation-delay: 0.45s; }
  .anim-d4 { animation-delay: 0.55s; }
  .anim-d5 { animation-delay: 0.7s; }
  .anim-d6 { animation-delay: 0.85s; }

  /* ---- HERO LAYOUT ---- */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    border-bottom: var(--border-brutal);
    background: var(--bg);
    overflow: hidden;
    position: relative;
  }

  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 120px 24px 40px;
    width: 100%;
  }

  /* ---- INTRO ---- */
  .hero-intro {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2vw, var(--text-lg));
    color: var(--dark-grey);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .hero-intro strong {
    color: var(--text);
    font-weight: 700;
  }

  /* ---- TITLE WRAPPER ---- */
  .hero-title-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin-bottom: 24px;
  }

  /* ---- SOLID FILLED TITLE ---- */
  .hero-title-solid {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 8vw, 8rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 1;
    margin: 0;
  }

  .hero-title-solid span {
    display: block;
  }

  /* ---- OUTLINE STROKE TITLE ---- */
  .hero-title-stroke {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 8vw, 8rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 1;
    margin: 0;
  }

  .hero-title-stroke span {
    display: block;
    -webkit-text-stroke: 3px var(--text);
    color: transparent;
    transition: color 0.3s ease;
  }

  .hero-title-stroke span:hover {
    color: var(--primary);
  }

  /* ---- PHOTO OVERLAP ---- */
  .hero-photo {
    position: absolute;
    bottom: -60px; /* Pull photo down */
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
  }

  .photo-frame {
    width: 260px;
    height: 320px;
    overflow: hidden;
    border: var(--border-brutal);
    box-shadow: 8px 8px 0 var(--primary);
    background: var(--white);
    transition: all 0.25s ease;
  }

  .hero-photo:hover .photo-frame {
    box-shadow: 4px 4px 0 var(--secondary);
    transform: scale(1.03);
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .photo-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, var(--primary) 0%, #ffe566 60%, var(--bg) 100%);
  }

  .photo-initials {
    font-family: var(--font-sans);
    font-size: 6rem;
    font-weight: 900;
    color: var(--text);
    letter-spacing: -6px;
  }

  .photo-sticker {
    position: absolute;
    top: -14px;
    right: -24px;
    background: var(--secondary);
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 8px 14px;
    border: var(--border-thick);
    box-shadow: 3px 3px 0 var(--black);
    transform: rotate(12deg);
    z-index: 5;
    animation: sticker-wobble 4s ease-in-out infinite;
  }

  @keyframes sticker-wobble {
    0%, 100% { transform: rotate(10deg); }
    50% { transform: rotate(15deg); }
  }



  /* ---- CTAs ---- */
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 1px;
    border: var(--border-thick);
    transition: all 0.15s ease;
  }

  .cta-primary {
    background: var(--primary);
    color: var(--black);
    box-shadow: var(--shadow-sm);
  }

  .cta-primary:hover {
    box-shadow: none;
    transform: translate(4px, 4px);
    background: var(--secondary);
    color: var(--white);
  }

  .cta-secondary {
    background: var(--white);
    color: var(--black);
    box-shadow: var(--shadow-sm);
  }

  .cta-secondary:hover {
    box-shadow: none;
    transform: translate(4px, 4px);
  }

  .cta-arrow {
    font-size: 1.2rem;
    transition: transform 0.2s ease;
  }

  .cta-primary:hover .cta-arrow {
    transform: translate(3px, -3px);
  }

  /* ---- MARQUEE ---- */
  .hero > .marquee-strip {
    margin-top: auto;
    flex-shrink: 0;
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 1024px) {
    .hero-title-solid,
    .hero-title-stroke {
      font-size: clamp(2.5rem, 7vw, 6rem);
    }

    .photo-frame {
      width: 220px;
      height: 270px;
    }


  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 100px 16px 32px;
    }

    .hero-title-solid,
    .hero-title-stroke {
      font-size: clamp(2rem, 9vw, 4.5rem);
      letter-spacing: -0.04em;
    }

    .hero-title-stroke span {
      -webkit-text-stroke-width: 2px;
    }

    .photo-frame {
      width: 180px;
      height: 230px;
    }

    .photo-initials {
      font-size: 4rem;
      letter-spacing: -3px;
    }

    .cta-btn {
      padding: 14px 28px;
      font-size: var(--text-xs);
    }


  }

  @media (max-width: 480px) {
    .hero-title-solid,
    .hero-title-stroke {
      font-size: clamp(1.5rem, 10vw, 3rem);
    }

    .photo-frame {
      width: 150px;
      height: 190px;
    }

    .hero-photo {
      margin: -10px 0;
    }

    .photo-sticker {
      font-size: 8px;
      padding: 5px 10px;
      right: -16px;
    }
  }
</style>
