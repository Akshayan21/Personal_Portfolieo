---
// Chapter 01: The Designer — Hero
---

<section class="hero" id="hero">
  <!-- Grain overlay -->
  <div class="grain"></div>

  <div class="hero-inner">
    <!-- Sticker badge -->
    <div class="sticker reveal reveal-scale delay-2">
      <span>AVAILABLE FOR WORK ★</span>
    </div>

    <!-- Main name — z-index above photo -->
    <div class="hero-title-block">
      <p class="hero-chapter mono reveal reveal-up">CHAPTER 01 — THE DESIGNER</p>
      <h1 class="hero-name reveal reveal-up delay-1">
        <span class="name-line">Akshayan</span>
        <span class="name-line name-outline">Mohandass</span>
      </h1>
    </div>

    <!-- Tagline with scramble -->
    <div class="hero-tagline reveal reveal-up delay-2">
      <p class="tagline-static">Designing the infrastructure for</p>
      <p class="tagline-dynamic" data-scramble="Intelligent Organizations|Complex Systems|AI-Driven Products|Enterprise Scale">
        Intelligent Organizations
      </p>
    </div>

    <!-- Statement -->
    <div class="hero-statement reveal reveal-up delay-3">
      <div class="statement-bar"></div>
      <p>I don't design interfaces.<br/><strong>I design how decisions move.</strong></p>
    </div>

    <!-- CTA row -->
    <div class="hero-cta reveal reveal-up delay-4">
      <a href="#experience" class="cta-brutal">
        VIEW MY WORK
        <span class="cta-arrow">↗</span>
      </a>
      <a href="#contact" class="cta-outline">SAY HELLO</a>
    </div>

    <!-- Photo card — right side -->
    <div class="photo-card reveal reveal-scale delay-3">
      <div class="pc-frame">
        <div class="pc-image">
          <img src="/hero-portrait.png" alt="Akshayan Mohandass" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="pc-placeholder">
            <span class="pc-initials">AM</span>
            <span class="pc-hint mono">YOUR PHOTO</span>
          </div>
        </div>
        <div class="pc-caption mono">
          <span>AKSHAYAN M.</span>
          <span class="pc-dot">●</span>
          <span>2026</span>
        </div>
      </div>
      <!-- Role sticker on card -->
      <div class="pc-sticker">
        <span>DESIGNER ✦</span>
      </div>
    </div>

    <!-- Small deco -->
    <div class="deco deco-cross" data-parallax="-0.15">✦</div>
  </div>

  <!-- Marquee -->
  <div class="marquee-strip">
    <div class="marquee-inner">
      PRODUCT DESIGNER ✦ SYSTEMS THINKER ✦ AI-NATIVE ✦ UX ARCHITECT ✦ ENTERPRISE ✦ PRODUCT DESIGNER ✦ SYSTEMS THINKER ✦ AI-NATIVE ✦ UX ARCHITECT ✦ ENTERPRISE ✦ PRODUCT DESIGNER ✦ SYSTEMS THINKER ✦ AI-NATIVE ✦ UX ARCHITECT ✦ ENTERPRISE ✦&nbsp;
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-bottom: var(--border-brutal);
    overflow: hidden;
  }

  .grain {
    position: absolute; inset: 0; pointer-events: none; opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    animation: grain 8s steps(10) infinite;
  }

  .hero-inner {
    position: relative; z-index: 1;
    max-width: 1200px; margin: 0 auto; padding: 120px 24px 80px;
    display: flex; flex-direction: column; align-items: flex-start;
  }

  .hero-title-block {
    position: relative;
    z-index: 5;
  }

  /* Sticker */
  .sticker {
    position: absolute; top: 120px; right: 60px;
    background: var(--neon-green);
    border: var(--border-thick);
    box-shadow: var(--shadow-sm);
    padding: 12px 20px;
    font-family: var(--font-mono);
    font-size: 12px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase;
    transform: rotate(12deg);
    animation: wobble 3s ease-in-out infinite;
    z-index: 5;
  }

  /* Chapter label */
  .hero-chapter {
    font-size: 12px; font-weight: 700;
    letter-spacing: 4px;
    color: var(--grey);
    margin-bottom: 20px;
  }

  /* Name */
  .hero-name {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -3px;
    margin-bottom: 24px;
  }

  .name-line {
    display: block;
  }

  .name-outline {
    -webkit-text-stroke: 3px var(--black);
    color: transparent;
    transition: all 0.3s ease;
  }

  .name-outline:hover {
    color: var(--neon-green);
    -webkit-text-stroke: 3px var(--black);
  }

  /* Tagline */
  .hero-tagline {
    margin-bottom: 24px;
  }

  .tagline-static {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 700;
    font-style: italic;
    color: var(--dark-grey);
    margin-bottom: 4px;
  }

  .tagline-dynamic {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    font-weight: 700;
    color: var(--neon-pink);
    min-height: 1.5em;
  }

  :global(.scramble-char) {
    color: var(--grey);
    font-weight: 400;
  }

  /* Statement */
  .hero-statement {
    display: flex; align-items: flex-start; gap: 16px;
    margin-bottom: 36px;
    max-width: 500px;
  }

  .statement-bar {
    width: 4px; min-height: 100%; flex-shrink: 0;
    background: var(--neon-pink);
  }

  .hero-statement p {
    font-size: 1rem;
    color: var(--dark-grey);
    line-height: 1.7;
  }

  .hero-statement strong {
    color: var(--black);
    font-weight: 700;
  }

  /* CTA */
  .hero-cta {
    display: flex; gap: 16px; flex-wrap: wrap;
  }

  .cta-brutal {
    font-family: var(--font-mono);
    font-size: 14px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    background: var(--black);
    color: var(--neon-green);
    padding: 16px 28px;
    border: var(--border-thick);
    box-shadow: var(--shadow-neon);
    display: inline-flex; align-items: center; gap: 10px;
    transition: all 0.15s ease;
  }

  .cta-brutal:hover {
    box-shadow: none;
    transform: translate(6px, 6px);
  }

  .cta-arrow {
    font-size: 1.2rem;
    transition: transform 0.2s ease;
  }

  .cta-brutal:hover .cta-arrow {
    transform: translate(3px, -3px);
  }

  .cta-outline {
    font-family: var(--font-mono);
    font-size: 14px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    background: transparent;
    color: var(--black);
    padding: 16px 28px;
    border: var(--border-thick);
    box-shadow: var(--shadow-sm);
    transition: all 0.15s ease;
  }

  .cta-outline:hover {
    background: var(--neon-pink);
    color: var(--white);
    box-shadow: none;
    transform: translate(4px, 4px);
  }

  /* Decorative */
  .deco { position: absolute; pointer-events: none; }

  .deco-cross {
    font-size: 3rem; color: var(--neon-pink);
    top: 40%; right: 15%;
    animation: float-slow 6s ease-in-out infinite;
  }

  /* Photo Card — sits BEHIND the name text */
  .photo-card {
    position: absolute;
    top: 50%;
    right: 80px;
    transform: translateY(-50%) rotate(-3deg);
    z-index: 2;
  }

  .pc-frame {
    border: var(--border-brutal);
    box-shadow: 8px 8px 0 var(--neon-green);
    background: var(--white);
    width: 240px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .photo-card:hover .pc-frame {
    transform: rotate(2deg);
    box-shadow: 4px 4px 0 var(--neon-green);
  }

  .pc-image {
    width: 240px;
    height: 280px;
    overflow: hidden;
    position: relative;
    background: var(--cream);
    border-bottom: var(--border-thick);
  }

  .pc-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pc-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    gap: 8px;
    background: linear-gradient(135deg, #e8e3d6, #d9d4c7);
  }

  .pc-initials {
    font-family: var(--font-sans);
    font-size: 4rem;
    font-weight: 900;
    color: var(--black);
    letter-spacing: -2px;
    line-height: 1;
  }

  .pc-hint {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--grey);
  }

  .pc-caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--dark-grey);
  }

  .pc-dot {
    color: var(--neon-green);
    font-size: 8px;
  }

  .pc-sticker {
    position: absolute;
    top: -12px;
    right: -14px;
    background: var(--neon-pink);
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 6px 12px;
    border: 2px solid var(--black);
    box-shadow: 3px 3px 0 var(--black);
    transform: rotate(8deg);
    z-index: 5;
  }

  /* Marquee at bottom of hero */
  .hero > .marquee-strip {
    margin-top: auto;
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .photo-card {
      position: relative;
      top: auto; right: auto;
      transform: rotate(-2deg);
      margin-top: 40px;
      align-self: center;
    }
  }

  @media (max-width: 768px) {
    .hero-inner { padding: 100px 16px 60px; }
    .sticker { top: 90px; right: 16px; font-size: 10px; padding: 8px 14px; }
    .deco-cross { display: none; }
    .name-outline { -webkit-text-stroke-width: 2px; }
    .cta-brutal, .cta-outline { font-size: 12px; padding: 12px 20px; }
    .photo-card { transform: rotate(-1deg); }
    .pc-frame { width: 200px; }
    .pc-image { width: 200px; height: 240px; }
    .pc-initials { font-size: 3rem; }
  }
</style>
