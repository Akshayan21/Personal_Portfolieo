    }

    .portfolio-container {
      position: static !important;
      width: 100% !important;
      height: auto !important;
    }
  }
</style>

<!-- Figma Core Canvas Engine Script -->
<script>
  // DOM selectors
  const viewport = document.getElementById('canvas-viewport');
  const container = document.getElementById('canvas-container');
  const frame = document.getElementById('figma-frame');
  const frameHeader = document.getElementById('frame-header');

  const selectionBox = document.getElementById('selection-box');
  const selectionTag = document.getElementById('selection-tag');
  const hoverBox = document.getElementById('hover-box');

  const zoomDropdown = document.getElementById('zoom-dropdown');
  const zoomDisplay = document.getElementById('zoom-percent-display');

  // Sidebar controls
  const sidebarLeft = document.getElementById('sidebar-left');
  const sidebarRight = document.getElementById('sidebar-right');
  const toggleLayersBtn = document.getElementById('toggle-layers');
  const togglePropertiesBtn = document.getElementById('toggle-properties');

  // Property Panel fields
  const controlNoSelectionMsg = document.getElementById('no-selection-prompt');
  const controlSelectionControls = document.getElementById('selection-controls');
  const propSelectedTag = document.getElementById('prop-selected-tag');
  const propFontFamily = document.getElementById('prop-font-family');
  const propFontSize = document.getElementById('prop-font-size');
  const propTextAlign = document.getElementById('prop-text-align');
  const propTextColor = document.getElementById('prop-text-color');
  const propTextColorHex = document.getElementById('prop-text-color-hex');
  const propBgColor = document.getElementById('prop-bg-color');
  const propBgColorHex = document.getElementById('prop-bg-color-hex');

  // Dynamic Theme Token inputs
  const tokenPrimary = document.getElementById('token-primary');
  const tokenPrimaryHex = document.getElementById('token-primary-hex');
  const tokenSecondary = document.getElementById('token-secondary');
  const tokenSecondaryHex = document.getElementById('token-secondary-hex');
  const tokenBg = document.getElementById('token-bg');
  const tokenBgHex = document.getElementById('token-bg-hex');
  const tokenText = document.getElementById('token-text');
  const tokenTextHex = document.getElementById('token-text-hex');

  // Tool Elements
  const toolButtons = document.querySelectorAll('.tool-btn');

  // Infinite Canvas state variables
  let scale = 0.85;
  let translateX = 100;
  let translateY = 80;

  let isPanning = false;
  let panStart = { x: 0, y: 0 };
  let isSpacePressed = false;
  let activeTool = 'select'; // select, hand, text, comment

  // Element selections
  let hoveredElement = null;
  let selectedElement = null;

  // Helper to determine if viewport is currently standard mobile/tablet view
  function isMobileView() {
    return window.innerWidth <= 768;
  }

  // Initialize Canvas Coordinates and transforms
  function updateCanvasTransform() {
    if (isMobileView()) {
      container.style.transform = '';
      frameHeader.style.transform = '';
      return;
    }

    container.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    
    // Position Frame Header right above the frame bounds
    frameHeader.style.transform = `translate(${translateX}px, ${translateY - 26}px) scale(${Math.max(0.7, Math.min(1, scale))})`;
    frameHeader.style.transformOrigin = 'left bottom';

    // Synchronize zoom indicator
    zoomDisplay.innerText = `${Math.round(scale * 100)}%`;

    // Recalculate overlays
    updateSelectionOverlay();
    updateHoverOverlay();
  }

  // Set zoom levels smoothly, mapping standard delta heights
  function adjustZoom(factor, clientX, clientY) {
    if (isMobileView()) return;
    const prevScale = scale;
    scale = Math.min(Math.max(scale * factor, 0.15), 4); // Bounds between 15% and 400%
    
    // Math to zoom into current mouse position clientX/clientY
    const rect = viewport.getBoundingClientRect();
    const mouseX = clientX - rect.left;
    const mouseY = clientY - rect.top;

    translateX = mouseX - (mouseX - translateX) * (scale / prevScale);
    translateY = mouseY - (mouseY - translateY) * (scale / prevScale);

    updateCanvasTransform();
  }

  // Fits the Figma Frame exactly centered in screen space
  function zoomToFit() {
    if (isMobileView()) {
      // Clear transformations on resize to mobile
      container.style.transform = '';
      frameHeader.style.transform = '';
      return;
    }
    const vw = viewport.clientWidth;
    const vh = viewport.clientHeight;
    const fw = frame.offsetWidth;
    const fh = frame.offsetHeight;

    // Update dimensions inputs dynamically in Properties panel!
    const dimW = document.getElementById('prop-dim-w');
    const dimH = document.getElementById('prop-dim-h');
    if (dimW) dimW.value = fw;
    if (dimH) dimH.value = fh;

    // Calc scale to fit width with some side margins
    const margin = 60;
    const scaleX = (vw - margin * 2) / fw;
    
    scale = Math.min(Math.max(scaleX, 0.25), 0.95);
    
    // Center frame in view
    translateX = (vw - fw * scale) / 2;
    translateY = 40; // Small spacer top

    updateCanvasTransform();
  }

  // Panning mechanics
  function startPan(clientX, clientY) {
    if (isMobileView()) return;
    isPanning = true;
    panStart = { x: clientX - translateX, y: clientY - translateY };
    if (activeTool === 'hand') {
      viewport.classList.add('figma-cursor-hand-active');
    }
  }

  function handlePan(clientX, clientY) {
    if (isMobileView() || !isPanning) return;
    translateX = clientX - panStart.x;
    translateY = clientY - panStart.y;
    updateCanvasTransform();
  }

  function endPan() {
    isPanning = false;
    viewport.classList.remove('figma-cursor-hand-active');
  }

  // Wheel events (pinch zoom + tracks scrolling)
  viewport.addEventListener('wheel', (e) => {
    if (isMobileView()) return; // Native scrolling works on mobile
    e.preventDefault();
    if (e.ctrlKey) {
      // Zoom
      const factor = e.deltaY < 0 ? 1.08 : 0.92;
      adjustZoom(factor, e.clientX, e.clientY);
    } else {
      // Pan with double-finger or scroll drag
      translateX -= e.deltaX;
      translateY -= e.deltaY;
      updateCanvasTransform();
    }
  }, { passive: false });

  // Mouse pan triggers
  viewport.addEventListener('mousedown', (e) => {
    if (isMobileView()) return; // Native mouse interactions on mobile

    // Do not drop comment pins when clicking inside comment popovers or on existing pins!
    if (e.target.closest('.comment-popover') || e.target.closest('.comment-pin')) {
      return;
    }

    // Middle-click or Hand tool drag or Spacebar + drag
    if (e.button === 1 || activeTool === 'hand' || isSpacePressed) {
      e.preventDefault();
      startPan(e.clientX, e.clientY);
      return;
    }

    // Left-click with Comment Tool drops a comment pin
    if (e.button === 0 && activeTool === 'comment') {
      e.preventDefault();
      dropCommentPin(e.clientX, e.clientY);
      return;
    }
  });

  // Track dragging across viewport
  window.addEventListener('mousemove', (e) => {
    if (isPanning) {
      handlePan(e.clientX, e.clientY);
    }
  });

  window.addEventListener('mouseup', () => {
    if (isPanning) {
      endPan();
    }
  });

  // Bounding Selection outline calculations
  function selectElement(elem) {
    // Prevent selecting framework layouts or Figma editor components
    if (!elem || elem.closest('.figma-sidebar') || elem.closest('.figma-topbar') || elem.closest('.figma-frame-header') || elem.closest('.canvas-overlay-container') || elem.closest('.figma-revert-badge')) {
      deselect();
      return;
    }

    selectedElement = elem;
    updateSelectionOverlay();
    loadStyleProperties(elem);

    // Sync Active Layer tree node
    document.querySelectorAll('.layer-item').forEach(n => n.classList.remove('active'));
    // Find closest section layout ID
    const section = elem.closest('section') || elem.closest('nav') || elem.closest('footer');
    if (section && section.id) {
      const layerNode = document.querySelector(`.layer-item[data-target="${section.id}"]`);
      if (layerNode) layerNode.classList.add('active');
    }
  }

  function deselect() {
    selectedElement = null;
    selectionBox.style.display = 'none';
    
    // Reset properties panel to idle
    controlNoSelectionMsg.style.display = 'block';
    controlSelectionControls.style.display = 'none';

    document.querySelectorAll('.layer-item').forEach(n => n.classList.remove('active'));
    document.querySelector('.layer-item.frame-node').classList.add('active');
  }

  function updateSelectionOverlay() {
    if (!selectedElement) {
      selectionBox.style.display = 'none';
      return;
    }

    const frameRect = frame.getBoundingClientRect();
    const elemRect = selectedElement.getBoundingClientRect();

    // Compute coordinate relative to the unscaled figma-frame
    const left = (elemRect.left - frameRect.left) / scale;
    const top = (elemRect.top - frameRect.top) / scale;
    const width = elemRect.width / scale;
    const height = elemRect.height / scale;

    selectionBox.style.left = `${left}px`;
    selectionBox.style.top = `${top}px`;
    selectionBox.style.width = `${width}px`;
    selectionBox.style.height = `${height}px`;
    selectionBox.style.display = 'block';

    const tagName = selectedElement.tagName.toLowerCase();
    selectionTag.innerText = `${tagName} | ${Math.round(width)} × ${Math.round(height)}`;
  }

  function updateHoverOverlay() {
    if (!hoveredElement || hoveredElement === selectedElement) {
      hoverBox.style.display = 'none';
      return;
    }

    const frameRect = frame.getBoundingClientRect();
    const elemRect = hoveredElement.getBoundingClientRect();

    const left = (elemRect.left - frameRect.left) / scale;
    const top = (elemRect.top - frameRect.top) / scale;
    const width = elemRect.width / scale;
    const height = elemRect.height / scale;

    hoverBox.style.left = `${left}px`;
    hoverBox.style.top = `${top}px`;
    hoverBox.style.width = `${width}px`;
    hoverBox.style.height = `${height}px`;
    hoverBox.style.display = 'block';
  }

  // Hover detection only inside Figma frame slot components
  frame.addEventListener('mousemove', (e) => {
    if (isMobileView()) return;
    if (activeTool !== 'select') {
      hoveredElement = null;
      hoverBox.style.display = 'none';
      return;
    }

    // Ignore frames, layers, overlays
    const target = e.target;
    if (target === frame || target.closest('.canvas-overlay-container') || target.closest('.figma-revert-badge')) {
      hoveredElement = null;
      hoverBox.style.display = 'none';
      return;
    }

    hoveredElement = target;
    updateHoverOverlay();
  });

  frame.addEventListener('mouseleave', () => {
    if (isMobileView()) return;
    hoveredElement = null;
    hoverBox.style.display = 'none';
  });

  // Handle single clicks inside Figma Portfolio Frame
  frame.addEventListener('click', (e) => {
    if (isMobileView()) return; // Regular clicks on mobile

    // If clicking inside comment popovers or comment pins, let events flow naturally to the forms/buttons
    if (e.target.closest('.comment-popover') || e.target.closest('.comment-pin')) {
      return;
    }

    // Comment mode disables all other layout interactions
    if (activeTool === 'comment') {
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    // Handle link clicks inside Figma Portfolio Frame
    const link = e.target.closest('a');
    if (link && link.getAttribute('href') && activeTool !== 'text') {
      const href = link.getAttribute('href');
      if (!href.startsWith('#') && !href.startsWith('javascript:')) {
        return; // Let the browser transition naturally to the respect page!
      } else if (href.startsWith('#')) {
        e.preventDefault();
        e.stopPropagation();
        const targetId = href.substring(1);
        const targetElem = document.getElementById(targetId);
        if (targetElem) {
          centerOnElement(targetElem);
        }
        return;
      }
    }

    // Select tool
    if (activeTool === 'select') {
      e.preventDefault();
      e.stopPropagation();
      selectElement(e.target);
      return;
    }

    // Text edit tool makes elements editable
    if (activeTool === 'text') {
      e.preventDefault();
      e.stopPropagation();
      initiateTextEditing(e.target);
    }
  });

  // Make text contenteditable
  function initiateTextEditing(elem) {
    // Filter editable text elements
    const isTextElement = ['h1', 'h2', 'h3', 'p', 'span', 'a', 'li', 'button', 'em', 'strong'].includes(elem.tagName.toLowerCase());
    if (!isTextElement) return;

    // Save original state (keep exact untrimmed text to prevent layout shift upon reversion)
    if (!elem.dataset.original) {
      elem.dataset.original = elem.innerText;
    }
    const originalText = elem.dataset.original;

    elem.contentEditable = 'true';
    elem.classList.add('figma-editing-text');
    elem.focus();

    // Select all text in node
    const range = document.createRange();
    range.selectNodeContents(elem);
    const selection = window.getSelection();
    selection.removeAllRanges();
    selection.addRange(range);

    function stopEditing() {
      elem.contentEditable = 'false';
      elem.classList.remove('figma-editing-text');
      
      const originalText = elem.dataset.original;
      const newText = elem.innerText;

      if (originalText !== newText && newText !== "") {
        triggerRevertCountdown(elem, originalText);
      }
      
      elem.removeEventListener('blur', stopEditing);
      elem.removeEventListener('keydown', keydownHandler);
    }

    function keydownHandler(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        stopEditing();
      }
      if (e.key === 'Escape') {
        e.preventDefault();
        elem.innerText = originalText;
        stopEditing();
      }
    }

    elem.addEventListener('blur', stopEditing);
    elem.addEventListener('keydown', keydownHandler);
  }

  // Ticks countdown spinners and reverts contents in 10 seconds
  const activeTimers = new Map();

  function triggerRevertCountdown(elem, originalText) {
    // Ensure relative positioning for correct bounding placement, tracking modifications
    const originalPos = window.getComputedStyle(elem).position;
    const inlinePos = elem.style.position;
    let positionModified = false;
    if (originalPos === 'static') {
      elem.style.position = 'relative';
      positionModified = true;
    }

    // Remove current timer if exists
    if (activeTimers.has(elem)) {
      const active = activeTimers.get(elem);
      clearInterval(active.intervalId);
      active.badge.remove();
    }

    // Inject countdown floating badge inside target node parent
    const badge = document.createElement('div');
    badge.className = 'figma-revert-badge';
    badge.innerHTML = `
      <svg class="revert-spinner" viewBox="0 0 20 20">
        <circle class="bg" cx="10" cy="10" r="8"></circle>
        <circle class="progress" cx="10" cy="10" r="8"></circle>
      </svg>
      <span>Reverting <strong class="timer-sec">10</strong>s</span>
    `;

    elem.parentNode.insertBefore(badge, elem);

    let timeLeft = 10;
    const progressCircle = badge.querySelector('.progress');
    const timeDisplay = badge.querySelector('.timer-sec');

    const perimeter = 50.26; // 2 * PI * r = 2 * 3.14159 * 8
    progressCircle.style.strokeDasharray = perimeter;
    progressCircle.style.strokeDashoffset = 0;

    const intervalId = setInterval(() => {
      timeLeft -= 0.1;
      if (timeLeft <= 0) {
        clearInterval(intervalId);
        badge.remove();
        activeTimers.delete(elem);

        // Revert copy
        elem.innerText = originalText;
        
        // Restore style position exactly to avoid lingering changes
        if (positionModified) {
          elem.style.position = inlinePos;
        }
        
        elem.classList.add('figma-reverted-flash');

        // Clean up flashes
        setTimeout(() => {
          elem.classList.remove('figma-reverted-flash');
        }, 1000);
        
        // Relayout boundaries
        updateSelectionOverlay();
      } else {
        timeDisplay.innerText = Math.ceil(timeLeft);
        progressCircle.style.strokeDashoffset = perimeter * (1 - (timeLeft / 10));
      }
    }, 100);

    activeTimers.set(elem, { intervalId, badge });
  }

  // Load selected element computed CSS inside Properties panel
  function loadStyleProperties(elem) {
    controlNoSelectionMsg.style.display = 'none';
    controlSelectionControls.style.display = 'block';

    propSelectedTag.innerText = elem.tagName.toLowerCase();
    
    const computed = window.getComputedStyle(elem);
    
    // Sync font size
    const size = parseInt(computed.fontSize);
    propFontSize.value = size;

    // Sync Align
    propTextAlign.value = computed.textAlign || 'left';

    // Helper: RGB to HEX converter
    function rgbToHex(rgbStr) {
      if (!rgbStr || rgbStr === 'transparent') return '#ffffff';
      const rgb = rgbStr.match(/^rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)$/);
      if (!rgb) return '#ffffff';
      const r = parseInt(rgb[1]).toString(16).padStart(2, '0');
      const g = parseInt(rgb[2]).toString(16).padStart(2, '0');
      const b = parseInt(rgb[3]).toString(16).padStart(2, '0');
      return `#${r}${g}${b}`;
    }

    // Set Fill Color inputs
    const textHex = rgbToHex(computed.color);
    propTextColor.value = textHex;
    propTextColorHex.innerText = textHex.toUpperCase();

    const bgHex = rgbToHex(computed.backgroundColor);
    propBgColor.value = bgHex;
    propBgColorHex.innerText = bgHex.toUpperCase();
  }

  // Bind properties panel style editors to update selected elements in real time!
  propFontSize.addEventListener('input', () => {
    if (!selectedElement) return;
    selectedElement.style.fontSize = `${propFontSize.value}px`;
    updateSelectionOverlay(); // Bounding box scales
  });

  propTextAlign.addEventListener('change', () => {
    if (!selectedElement) return;
    selectedElement.style.textAlign = propTextAlign.value;
  });

  propTextColor.addEventListener('input', () => {
    if (!selectedElement) return;
    selectedElement.style.color = propTextColor.value;
    propTextColorHex.innerText = propTextColor.value.toUpperCase();
  });

  propBgColor.addEventListener('input', () => {
    if (!selectedElement) return;
    selectedElement.style.backgroundColor = propBgColor.value;
    propBgColorHex.innerText = propBgColor.value.toUpperCase();
  });

  propFontFamily.addEventListener('change', () => {
    if (!selectedElement) return;
    selectedElement.style.fontFamily = `'${propFontFamily.value}', sans-serif`;
    updateSelectionOverlay();
  });

  // Global design tokens adjustments updating Root CSS Variables!
  tokenPrimary.addEventListener('input', () => {
    document.documentElement.style.setProperty('--primary', tokenPrimary.value);
    tokenPrimaryHex.innerText = tokenPrimary.value.toUpperCase();
  });

  tokenSecondary.addEventListener('input', () => {
    document.documentElement.style.setProperty('--secondary', tokenSecondary.value);
    tokenSecondaryHex.innerText = tokenSecondary.value.toUpperCase();
  });

  tokenBg.addEventListener('input', () => {
    document.documentElement.style.setProperty('--bg', tokenBg.value);
    tokenBgHex.innerText = tokenBg.value.toUpperCase();
  });

  tokenText.addEventListener('input', () => {
    document.documentElement.style.setProperty('--text', tokenText.value);
    tokenTextHex.innerText = tokenText.value.toUpperCase();
  });

  // Figma Comment System (persists absolute comments pins in local storage!)
  const pinsContainer = document.getElementById('comments-pins-container');
  let commentsList = [];

  function loadComments() {
    const stored = localStorage.getItem('figma_portfolio_comments');
    if (stored) {
      try {
        commentsList = JSON.parse(stored);
      } catch (err) {
        commentsList = [];
      }
    }
    renderComments();
  }

  function saveComments() {
    localStorage.setItem('figma_portfolio_comments', JSON.stringify(commentsList));
    renderComments();
  }

  function dropCommentPin(clientX, clientY) {
    const frameRect = frame.getBoundingClientRect();
    
    // Click position relative to portfolio Frame, normalized for current scale
    const px = (clientX - frameRect.left) / scale;
    const py = (clientY - frameRect.top) / scale;

    // Bounds check to ensure click is inside the frame area
    if (px < 0 || px > frame.offsetWidth || py < 0 || py > frame.offsetHeight) {
      return;
    }

    const tempId = Date.now();
    const commentObj = {
      id: tempId,
      x: px,
      y: py,
      author: "Guest",
      text: "",
      isNew: true
    };

    commentsList.push(commentObj);
    saveComments();
    
    // Automatically trigger edit modal popover
    setTimeout(() => {
      const pin = document.querySelector(`.comment-pin[data-id="${tempId}"]`);
      if (pin) pin.click();
    }, 50);
  }

  function renderComments() {
    pinsContainer.innerHTML = '';
    
    commentsList.forEach((c) => {
      const pin = document.createElement('div');
      pin.className = `comment-pin ${c.isNew ? 'new-pin' : ''}`;
      pin.setAttribute('data-id', c.id);
      pin.style.position = 'absolute';
      pin.style.left = `${c.x}px`;
      pin.style.top = `${c.y}px`;
      pin.style.pointerEvents = 'auto'; // Pins clickable
      
      // Pin visual
      pin.innerHTML = `
        <div class="pin-bubble" style="transform: scale(${Math.max(0.7, Math.min(1.3, 1/scale))}); transform-origin: center center;">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>
          </svg>
        </div>
      `;

      // Click to open comment thread card
      pin.addEventListener('click', (e) => {
        e.stopPropagation();
        openCommentThread(c, pin);
      });

      pinsContainer.appendChild(pin);
    });
  }

  function openCommentThread(comment, pinNode) {
    // Close other comment bubbles
    document.querySelectorAll('.comment-popover').forEach(p => p.remove());

    const popover = document.createElement('div');
    popover.className = 'comment-popover';
    
    // Build popover thread UI
    if (comment.isNew) {
      popover.innerHTML = `
        <div class="popover-head">New Comment</div>
        <div class="popover-body">
          <input type="text" class="comment-name-input" id="c-name" placeholder="Your name (e.g. Designer Alex)" />
          <textarea class="comment-text-input" id="c-text" placeholder="Write a comment on the canvas..."></textarea>
          <div class="popover-actions">
            <button class="pop-btn pop-btn-cancel" id="c-cancel">Discard</button>
            <button class="pop-btn pop-btn-save" id="c-save">Post Comment</button>
          </div>
        </div>
      `;
    } else {
      popover.innerHTML = `
        <div class="popover-head">
          <span class="p-author">${comment.author}</span>
          <button class="p-delete-btn" id="c-delete" title="Delete comment">×</button>
        </div>
        <div class="popover-comment-body">
          ${comment.text}
        </div>
      `;
    }

    // Styles for popover
    popover.style.position = 'absolute';
    popover.style.background = 'var(--figma-bg)';
    popover.style.border = '1px solid var(--figma-border)';
    popover.style.borderRadius = '8px';
    popover.style.boxShadow = '0 4px 16px rgba(0,0,0,0.3)';
    popover.style.padding = '12px';
    popover.style.width = '240px';
    popover.style.zIndex = '1200';
    popover.style.fontSize = '12px';
    
    // Scale and position relative to current zoom factor
    popover.style.transform = `scale(${Math.max(0.75, Math.min(1.2, 1/scale))})`;
    popover.style.transformOrigin = 'left top';
    popover.style.left = `${comment.x + 24}px`;
    popover.style.top = `${comment.y}px`;
    popover.style.pointerEvents = 'auto';

    pinsContainer.appendChild(popover);

    // Bind event handlers inside thread
    if (comment.isNew) {
      const nameInput = popover.querySelector('#c-name');
      const textInput = popover.querySelector('#c-text');
      nameInput.focus();

      popover.querySelector('#c-cancel').addEventListener('click', () => {
        commentsList = commentsList.filter(item => item.id !== comment.id);
        saveComments();
        popover.remove();
      });

      popover.querySelector('#c-save').addEventListener('click', () => {
        const textVal = textInput.value.trim();
        if (!textVal) return;

        comment.author = nameInput.value.trim() || "Anonymous Designer";
        comment.text = textVal;
        comment.isNew = false;
        
        saveComments();
        popover.remove();
      });
    } else {
      popover.querySelector('#c-delete').addEventListener('click', () => {
        commentsList = commentsList.filter(item => item.id !== comment.id);
        saveComments();
        popover.remove();
      });
    }
  }

  // Close comments cards when clicking empty space
  viewport.addEventListener('click', (e) => {
    if (!e.target.closest('.comment-popover') && !e.target.closest('.comment-pin')) {
      // Clean up any unsaved new comments so they don't persist on subsequent renders
      const activeNew = commentsList.some(item => item.isNew);
      if (activeNew) {
        commentsList = commentsList.filter(item => !item.isNew);
        saveComments();
      }
      document.querySelectorAll('.comment-popover').forEach(p => p.remove());
    }
  });

  // Toolbar Actions Selection handlers
  toolButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      toolButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const tool = btn.dataset.tool;
      activeTool = tool;
      
      // Update viewport cursor styles
      viewport.className = 'figma-canvas-viewport';
      if (tool === 'select') viewport.classList.add('figma-cursor-select');
      if (tool === 'hand') viewport.classList.add('figma-cursor-hand');
      if (tool === 'text') viewport.classList.add('figma-cursor-text');
      if (tool === 'comment') viewport.classList.add('figma-cursor-comment');

      // Clear selections on changing modes
      if (tool !== 'select') deselect();
    });
  });

  // Double check tool selections via keyboard shortcuts
  window.addEventListener('keydown', (e) => {
    // Ignore input focus triggers
    if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA' || document.activeElement.contentEditable === 'true') {
      return;
    }

    if (e.key.toLowerCase() === 'v') document.getElementById('tool-select').click();
    if (e.key.toLowerCase() === 'h') document.getElementById('tool-hand').click();
    if (e.key.toLowerCase() === 't') document.getElementById('tool-text').click();
    if (e.key.toLowerCase() === 'c') document.getElementById('tool-comment').click();
    if (e.key === ' ') {
      e.preventDefault();
      isSpacePressed = true;
      viewport.classList.add('figma-cursor-hand');
    }
    if (e.key === '0') {
      scale = 1;
      updateCanvasTransform();
    }
    if (e.key === '1') {
      zoomToFit();
    }
  });

  window.addEventListener('keyup', (e) => {
    if (e.key === ' ') {
      isSpacePressed = false;
      if (activeTool !== 'hand') {
        viewport.classList.remove('figma-cursor-hand');
      }
    }
  });

  // Layer Tree selection trigger scroll and centering on sections!
  document.querySelectorAll('.layer-item').forEach(item => {
    item.addEventListener('click', () => {
      const targetId = item.dataset.target;
      if (!targetId) return;

      const targetElem = document.getElementById(targetId);
      if (targetElem) {
        // Center canvas view around target element coordinates!
        centerOnElement(targetElem);
      } else if (targetId === 'figma-frame') {
        // Fit frame
        zoomToFit();
        selectElement(frame);
      }
    });
  });

  function centerOnElement(elem) {
    if (!elem) return;

    const vw = viewport.clientWidth;
    const vh = viewport.clientHeight;
    const fw = frame.offsetWidth;

    const frameRect = frame.getBoundingClientRect();
    const elemRect = elem.getBoundingClientRect();

    // Cumulative offset relative to the unscaled figma-frame container bounds
    const elemTop = (elemRect.top - frameRect.top) / scale;
    const elemLeft = (elemRect.left - frameRect.left) / scale;
    const elemWidth = elemRect.width / scale;
    const elemHeight = elemRect.height / scale;

    // Center translation points based on scale zoom factor
    translateX = (vw / 2) - (elemLeft + elemWidth / 2) * scale;
    translateY = (vh / 2) - (elemTop + elemHeight / 2) * scale;

    updateCanvasTransform();
    selectElement(elem);
  }

  // Sidebar Toggles
  toggleLayersBtn.addEventListener('click', () => {
    sidebarLeft.classList.toggle('closed');
    toggleLayersBtn.classList.toggle('active');
    setTimeout(zoomToFit, 260); // Relayout fit
  });

  togglePropertiesBtn.addEventListener('click', () => {
    sidebarRight.classList.toggle('closed');
    togglePropertiesBtn.classList.toggle('active');
    setTimeout(zoomToFit, 260); // Relayout fit
  });

  // Zoom Selector click trigger dropdown
  const zoomTrigger = document.getElementById('zoom-dropdown-trigger');
  zoomTrigger.addEventListener('click', (e) => {
    e.stopPropagation();
    zoomDropdown.classList.toggle('open');
  });

  window.addEventListener('click', () => {
    zoomDropdown.classList.remove('open');
  });

  document.querySelectorAll('.zoom-opt').forEach(opt => {
    opt.addEventListener('click', () => {
      const val = opt.dataset.zoom;
      if (val) {
        scale = parseInt(val) / 100;
        updateCanvasTransform();
      }
    });
  });

  document.getElementById('zoom-opt-fit').addEventListener('click', zoomToFit);

  // Close floating help toast
  document.getElementById('toast-close').addEventListener('click', () => {
    document.getElementById('alert-toast').style.display = 'none';
  });

  // Preloader progress bar animation
  function runPreloader() {
    const preloader = document.getElementById('preloader');
    const bar = document.getElementById('preloader-bar');
    const percent = document.getElementById('preloader-percent');
    const statusText = document.getElementById('preloader-status-text');
    
    if (!preloader || !bar || !percent) return;

    // Save flag inside session storage so internal page transitions skip the preloader
    sessionStorage.setItem('figma_preloader_shown', 'true');

    // Helper loading logs matching designer sandbox themes
    const logs = [
      "Connecting socket channels...",
      "Resolving design system tokens...",
      "Compiling vector bounds...",
      "Locking viewport transforms...",
      "Sandbox successfully initialized!"
    ];

    const duration = 10000; // Fixed 10-second duration to let users comfortably read the enhanced copy!
    const startTime = Date.now();

    const interval = setInterval(() => {
      const elapsed = Date.now() - startTime;
      let progress = Math.min((elapsed / duration) * 100, 100);

      bar.style.width = `${progress}%`;
      percent.innerText = `${Math.round(progress)}%`;

      if (progress >= 100) {
        clearInterval(interval);
        statusText.innerText = logs[logs.length - 1];

        // Sleek fade-out & scale-up hangar transitions
        setTimeout(() => {
          preloader.style.opacity = '0';
          preloader.style.transform = 'scale(1.05)';
          setTimeout(() => {
            preloader.remove();
          }, 500);
        }, 400);
      } else {
        // Dynamic logs based on thresholds
        const logIndex = Math.min(Math.floor(progress / 20), logs.length - 2);
        statusText.innerText = logs[logIndex];
      }
    }, 50); // Refresh progress bar smoothly 20 times per second
  }

  // Trigger loading sandbox animation immediately
  runPreloader();

  // Page Load Initial Setup
  window.addEventListener('load', () => {
    // Initial fitting alignment
    setTimeout(() => {
      zoomToFit();
      loadComments();
    }, 100);
  });

  // Recalculates canvas positioning if browser window changes width
  window.addEventListener('resize', () => {
    zoomToFit();
  });
</script>
