      display: block !important;
      width: 100% !important;
      height: auto !important;
      overflow: visible !important;
    }

    .figma-canvas-viewport {
      display: block !important;
      width: 100% !important;
      height: auto !important;
      background: transparent !important;
      background-image: none !important;
      overflow: visible !important;
