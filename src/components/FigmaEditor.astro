  /* ══════════════════════════════════════
     NATIVE MOBILE VIEW OVERRIDES (≤ 768px)
     Completely bypasses Figma Canvas and UI
     to display original responsive portfolio
  ══════════════════════════════════════ */
  @media (max-width: 768px) {
    .figma-topbar,
    .figma-sidebar-left,
    .figma-sidebar-right,
    .figma-frame-header,
