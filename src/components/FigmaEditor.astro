---
// FigmaEditor — interactive Figma Canvas wrapper for Personal Portfolio
const isProjectPage = Astro.url.pathname.includes('/projects/');
---

<div class="figma-editor">
  <!-- Experiential Sandbox Preloader -->
  <div class="sandbox-preloader" id="preloader">
    <script is:inline>
      (function() {
        var isReload = false;
        try {
          if (window.performance && window.performance.navigation) {
            isReload = window.performance.navigation.type === 1;
          }
          var navEntries = performance.getEntriesByType('navigation');
          if (navEntries.length > 0) {
            isReload = navEntries[0].type === 'reload';
          }
        } catch (e) {}
        
        var isFirstVisit = !sessionStorage.getItem('figma_preloader_shown');
        if (isReload || isFirstVisit) {
          // If first visit or page reload, force show the preloader immediately before paint
          document.write('<style>#preloader { display: flex !important; }</style>');
        } else {
          // Otherwise, keep it display: none, and clean it up from DOM on DOM ready
          document.addEventListener('DOMContentLoaded', function() {
            var p = document.getElementById('preloader');
            if (p) p.remove();
          });
        }
      })();
    </script>
    <div class="preloader-card">
      <div class="preloader-browser-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="preloader-title-file">Akshayan_Mohandass_Portfolio_v2.fig</span>
      </div>
      
      <div class="preloader-body">
        <div class="preloader-figma-logo">
          <svg viewBox="0 0 36 36" class="spinning-logo">
            <path d="M12 6a6 6 0 0 1 6 6v6H12a6 6 0 0 1 0-12z" fill="#F24E1E"></path>
            <path d="M24 12a6 6 0 0 1-6 6h6a6 6 0 0 1 0-12z" fill="#FF7262"></path>
            <path d="M12 18a6 6 0 0 1 6 6v6H12a6 6 0 0 1 0-12z" fill="#1ABC9C"></path>
            <path d="M24 24a6 6 0 0 1-6 6 6 6 0 0 1-6-6h12z" fill="#0ACF83"></path>
            <path d="M24 18a6 6 0 0 1-6 6v-12a6 6 0 0 1 6 6z" fill="#18A0FB"></path>
          </svg>
        </div>
        
        <h2 class="preloader-heading mono">INITIALIZING DESIGN SANDBOX</h2>
        
        <p class="preloader-copy">
          Welcome to a living product environment. This is an <strong>experiential design sandbox</strong> where intelligence meets interface constraints.
          <br/><br/>
          Feel free to inspect structures, click & edit any text, drop comment pins, and explore this world at will.
        </p>

        <!-- Dynamic Terminal Progress Bar -->
        <div class="preloader-progress-container">
          <div class="preloader-bar" id="preloader-bar"></div>
        </div>
        <div class="preloader-status mono">
          <span id="preloader-status-text">Booting canvas coordinates...</span>
          <span id="preloader-percent">0%</span>
        </div>
      </div>
    </div>
  </div>
  <!-- Top Menu Bar -->
  <header class="figma-topbar">
    <div class="topbar-left">
      <!-- Figma Logo Badge -->
      <div class="figma-logo-badge" title="Figma Design Environment">
        <svg viewBox="0 0 36 36" class="figma-logo-svg">
          <path d="M12 6a6 6 0 0 1 6 6v6H12a6 6 0 0 1 0-12z" fill="#F24E1E"></path>
          <path d="M24 12a6 6 0 0 1-6 6h6a6 6 0 0 1 0-12z" fill="#FF7262"></path>
          <path d="M12 18a6 6 0 0 1 6 6v6H12a6 6 0 0 1 0-12z" fill="#1ABC9C"></path>
          <path d="M24 24a6 6 0 0 1-6 6 6 6 0 0 1-6-6h12z" fill="#0ACF83"></path>
          <path d="M24 18a6 6 0 0 1-6 6v-12a6 6 0 0 1 6 6z" fill="#18A0FB"></path>
        </svg>
      </div>

      <div class="topbar-divider"></div>

      <!-- File Title -->
      <div class="figma-file-info">
        <span class="file-name">Akshayan Mohandass — Portfolio</span>
        <span class="file-status">Draft</span>
      </div>
    </div>

    <!-- Active Tool Selector -->
    <div class="topbar-center">
      <div class="tool-selector">
        <button class="tool-btn active" id="tool-select" data-tool="select" title="Move Tool (V)">
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path d="M5.5 3.5l14 9.5-6.5 1.5 4.5 6-2 1.5-4.5-6-5.5 4z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
          </svg>
        </button>
        <button class="tool-btn" id="tool-hand" data-tool="hand" title="Hand Tool (H) — Spacebar + Drag">
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path d="M12 3a1.5 1.5 0 011.5 1.5v6a1.5 1.5 0 01-3 0v-6A1.5 1.5 0 0112 3zM15.5 5.5a1.5 1.5 0 011.5 1.5v4.5a1.5 1.5 0 01-3 0V7a1.5 1.5 0 011.5-1.5zM8.5 7.5a1.5 1.5 0 011.5 1.5v3.5a1.5 1.5 0 01-3 0V9a1.5 1.5 0 011.5-1.5zM19 8.5a1.5 1.5 0 011.5 1.5v4a6 6 0 01-12 0v-.5a1.5 1.5 0 013 0v.5a3 3 0 006 0v-4A1.5 1.5 0 0119 8.5z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
          </svg>
        </button>
        <button class="tool-btn" id="tool-text" data-tool="text" title="Text Tool (T) — Click to Edit Text">
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path d="M5 4h14v3h-2V6H13v12h2v2H9v-2h2V6H7v1H5V4z" fill="currentColor"></path>
          </svg>
        </button>
        <button class="tool-btn" id="tool-comment" data-tool="comment" title="Add Comment Pin (C)">
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Topbar Actions & Zoom -->
    <div class="topbar-right">
      <button class="toggle-sidebar-btn" id="toggle-layers" title="Toggle Layers Panel">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path d="M4 6h16M4 12h16M4 18h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
        <span>Layers</span>
      </button>

      <button class="toggle-sidebar-btn" id="toggle-properties" title="Toggle Design Properties">
        <span>Design</span>
        <svg viewBox="0 0 24 24" width="16" height="16">
          <rect x="4" y="4" width="16" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="2"></rect>
          <path d="M14 4v16" fill="none" stroke="currentColor" stroke-width="2"></path>
        </svg>
      </button>

      <div class="topbar-divider"></div>

      <!-- Zoom Controller -->
      <div class="zoom-selector">
        <button class="zoom-trigger" id="zoom-dropdown-trigger">
          <span id="zoom-percent-display">85%</span>
          <svg viewBox="0 0 24 24" width="10" height="10">
            <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="zoom-dropdown" id="zoom-dropdown">
          <button class="zoom-opt" data-zoom="50">50%</button>
          <button class="zoom-opt" data-zoom="75">75%</button>
          <button class="zoom-opt" data-zoom="85">85% (Fit)</button>
          <button class="zoom-opt" data-zoom="100">100%</button>
          <button class="zoom-opt" data-zoom="150">150%</button>
          <button class="zoom-opt" data-zoom="200">200%</button>
          <div class="dropdown-divider"></div>
          <button class="zoom-opt" id="zoom-opt-fit">Zoom to Fit</button>
        </div>
      </div>

      <button class="share-btn">Share</button>
      <button class="present-btn" title="Present Mode">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </button>
    </div>
  </header>

  <!-- Workspace Shell -->
  <div class="figma-workspace">
    <!-- Left Sidebar (Layers Panel) -->
    <aside class="figma-sidebar figma-sidebar-left" id="sidebar-left">
      <div class="sidebar-tabs">
        <button class="sidebar-tab active">Layers</button>
        <button class="sidebar-tab">Assets</button>
      </div>

      <div class="layers-container">
        <!-- Root Frame Node -->
        <div class="layer-item frame-node active" data-target="figma-frame">
          <span class="layer-chevron">
            <svg viewBox="0 0 24 24" width="12" height="12">
              <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
          <span class="layer-icon">＃</span>
          <span class="layer-name">Desktop - 1440</span>
        </div>

        <!-- Portfolio Sections List -->
        <div class="layer-children">
          {!isProjectPage ? (
            <>
              <div class="layer-item" data-target="navbar">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🧭</span>
                <span class="layer-name">Navigation</span>
              </div>
              <div class="layer-item" data-target="hero">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">⚡</span>
                <span class="layer-name">01. Hero Area</span>
              </div>
              <div class="layer-item" data-target="about">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">📖</span>
                <span class="layer-name">02. Origin Story</span>
              </div>
              <div class="layer-item" data-target="experience">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">💼</span>
                <span class="layer-name">03. Journey</span>
              </div>
              <div class="layer-item" data-target="projects">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🎨</span>
                <span class="layer-name">04. Works Gallery</span>
              </div>
              <div class="layer-item" data-target="skills">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🛠️</span>
                <span class="layer-name">05. Arsenal</span>
              </div>
              <div class="layer-item" data-target="philosophy">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">💭</span>
                <span class="layer-name">06. Philosophy</span>
              </div>
              <div class="layer-item" data-target="contact">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">✉️</span>
                <span class="layer-name">07. Say Hello</span>
              </div>
              <div class="layer-item" data-target="footer">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">⚓</span>
                <span class="layer-name">Footer</span>
              </div>
            </>
          ) : (
            <>
              <div class="layer-item" data-target="cs-topnav">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🧭</span>
                <span class="layer-name">Top Nav Bar</span>
              </div>
              <div class="layer-item" data-target="cs-hero">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">⚡</span>
                <span class="layer-name">Header Hero</span>
              </div>
              <div class="layer-item" data-target="cs-overview">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">📖</span>
                <span class="layer-name">01. Overview</span>
              </div>
              <div class="layer-item" data-target="cs-challenge">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">💼</span>
                <span class="layer-name">02. Challenge</span>
              </div>
              <div class="layer-item" data-target="cs-research">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🔬</span>
                <span class="layer-name">03. Research</span>
              </div>
              <div class="layer-item" data-target="cs-process">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🛠️</span>
                <span class="layer-name">04. Design Process</span>
              </div>
              <div class="layer-item" data-target="cs-screens">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">💭</span>
                <span class="layer-name">05. Key Screens</span>
              </div>
              <div class="layer-item" data-target="cs-decisions">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">✉️</span>
                <span class="layer-name">06. Decisions</span>
              </div>
              <div class="layer-item" data-target="cs-outcomes">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">📈</span>
                <span class="layer-name">07. Outcomes</span>
              </div>
              <div class="layer-item" data-target="cs-learnings">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">⚓</span>
                <span class="layer-name">08. Learnings</span>
              </div>
              <div class="layer-item" data-target="cs-project-nav">
                <span class="layer-indent"></span>
                <span class="layer-icon-type">🧭</span>
                <span class="layer-name">Navigation Strip</span>
              </div>
            </>
          )}
        </div>
      </div>
      
      <div class="layers-footer">
        <div class="shortcuts-hint">
          <div class="hint-title">Canvas Shortcuts</div>
          <div class="hint-row"><span>V</span> Move Tool</div>
          <div class="hint-row"><span>H</span> Hand Tool</div>
          <div class="hint-row"><span>T</span> Text Tool (Edit)</div>
          <div class="hint-row"><span>C</span> Comment Pin</div>
          <div class="hint-row"><span>Space + Drag</span> Pan Workspace</div>
          <div class="hint-row"><span>Wheel Scroll</span> Zoom In/Out</div>
        </div>
      </div>
    </aside>

    <!-- Canvas Viewport -->
    <main class="figma-canvas-viewport" id="canvas-viewport">
      <!-- Figma Frame Title Header -->
      <div class="figma-frame-header" id="frame-header">
        <span class="frame-hash">＃</span> Desktop - 1440
      </div>

      <!-- Infinite Workspace Grid -->
      <div class="figma-canvas-container" id="canvas-container">

        <!-- Figma Frame wrapper around Portfolio Content -->
        <div class="figma-frame" id="figma-frame">
          <div class="portfolio-container">
            <slot />
          </div>
        </div>

        <!-- Overlays Layer (Absolute to canvas coordinate system) -->
        <div class="canvas-overlay-container" id="overlay-container">
          <!-- Selection Bounding Box -->
          <div class="figma-selection-box" id="selection-box" style="display: none;">
            <div class="selection-border border-top"></div>
            <div class="selection-border border-right"></div>
            <div class="selection-border border-bottom"></div>
            <div class="selection-border border-left"></div>
            
            <div class="selection-handle top-left"></div>
            <div class="selection-handle top-right"></div>
            <div class="selection-handle bottom-left"></div>
            <div class="selection-handle bottom-right"></div>
            
            <div class="selection-tag" id="selection-tag">div | 1440 x 800</div>
          </div>

          <!-- Hover Border Highlight -->
          <div class="figma-hover-box" id="hover-box" style="display: none;"></div>

          <!-- Comments Pins Container -->
          <div class="canvas-comments-container" id="comments-pins-container"></div>
        </div>

      </div>
    </main>

    <!-- Right Sidebar (Design Properties Panel) -->
    <aside class="figma-sidebar figma-sidebar-right" id="sidebar-right">
      <div class="sidebar-tabs">
        <button class="sidebar-tab active">Design</button>
        <button class="sidebar-tab">Prototype</button>
        <button class="sidebar-tab">Inspect</button>
      </div>

      <div class="properties-container">
        <!-- Section 1: Dimensions & Constraints -->
        <div class="prop-section">
          <div class="prop-header">Frame Dimensions</div>
          <div class="prop-grid-2x2">
            <div class="prop-input-group">
              <span class="prop-label">X</span>
              <input type="text" class="prop-input" value="0" id="prop-dim-x" disabled />
            </div>
            <div class="prop-input-group">
              <span class="prop-label">Y</span>
              <input type="text" class="prop-input" value="0" id="prop-dim-y" disabled />
            </div>
            <div class="prop-input-group">
              <span class="prop-label">W</span>
              <input type="text" class="prop-input" value="1440" id="prop-dim-w" disabled />
            </div>
            <div class="prop-input-group">
              <span class="prop-label">H</span>
              <input type="text" class="prop-input" value="8400" id="prop-dim-h" disabled />
            </div>
          </div>
        </div>

        <!-- Section 2: Selected Element Style Properties -->
        <div class="prop-section" id="section-selection-details">
          <div class="prop-header">Selection Properties</div>
          <div class="no-selection-msg" id="no-selection-prompt">
            Click any element inside the portfolio with the Move Tool to inspect and tweak CSS styles!
          </div>

          <div class="selection-prop-controls" id="selection-controls" style="display: none;">
            <div class="prop-row">
              <span class="prop-row-label">Element</span>
              <span class="tag-badge" id="prop-selected-tag">h1</span>
            </div>

            <!-- Typography Inspector -->
            <div class="prop-subheader">Typography</div>
            
            <div class="prop-row">
              <span class="prop-row-label">Font Family</span>
              <select class="prop-select" id="prop-font-family">
                <option value="Inter">Inter (Sans)</option>
                <option value="Space Grotesk">Space Grotesk</option>
                <option value="JetBrains Mono">JetBrains Mono (Mono)</option>
                <option value="Playfair Display">Playfair Display (Serif)</option>
              </select>
            </div>

            <div class="prop-grid-2x1">
              <div class="prop-input-group">
                <span class="prop-label">Size</span>
                <input type="number" class="prop-input" id="prop-font-size" value="16" min="8" max="120" />
              </div>
              <div class="prop-input-group">
                <span class="prop-label">Align</span>
                <select class="prop-select" id="prop-text-align">
                  <option value="left">Left</option>
                  <option value="center">Center</option>
                  <option value="right">Right</option>
                </select>
              </div>
            </div>

            <!-- Color Fills -->
            <div class="prop-subheader">Color Settings</div>
            
            <div class="prop-row">
              <span class="prop-row-label">Text Color</span>
              <div class="color-picker-wrapper">
                <input type="color" class="color-picker-input" id="prop-text-color" value="#000000" />
                <span class="color-hex-label" id="prop-text-color-hex">#000000</span>
              </div>
            </div>

            <div class="prop-row">
              <span class="prop-row-label">BG Color</span>
              <div class="color-picker-wrapper">
                <input type="color" class="color-picker-input" id="prop-bg-color" value="#ffffff" />
                <span class="color-hex-label" id="prop-bg-color-hex">#FFFFFF</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Document Global Colors (Design Tokens) -->
        <div class="prop-section">
          <div class="prop-header">Document Colors (Design Tokens)</div>
          <div class="token-helper-text">Modify global CSS theme variables of the portfolio design system!</div>

          <div class="prop-row">
            <span class="prop-row-label">Primary Color</span>
            <div class="color-picker-wrapper">
              <div class="color-dot" style="background: var(--primary);"></div>
              <input type="color" class="color-picker-input" id="token-primary" value="#FDC800" />
              <span class="color-hex-label" id="token-primary-hex">#FDC800</span>
            </div>
          </div>

          <div class="prop-row">
            <span class="prop-row-label">Secondary Color</span>
            <div class="color-picker-wrapper">
              <div class="color-dot" style="background: var(--secondary);"></div>
              <input type="color" class="color-picker-input" id="token-secondary" value="#432DD7" />
              <span class="color-hex-label" id="token-secondary-hex">#432DD7</span>
            </div>
          </div>

          <div class="prop-row">
            <span class="prop-row-label">Body Background</span>
            <div class="color-picker-wrapper">
              <div class="color-dot" style="background: var(--bg);"></div>
              <input type="color" class="color-picker-input" id="token-bg" value="#FBFBF9" />
              <span class="color-hex-label" id="token-bg-hex">#FBFBF9</span>
            </div>
          </div>

          <div class="prop-row">
            <span class="prop-row-label">Text Color</span>
            <div class="color-picker-wrapper">
              <div class="color-dot" style="background: var(--text);"></div>
              <input type="color" class="color-picker-input" id="token-text" value="#1C293C" />
              <span class="color-hex-label" id="token-text-hex">#1C293C</span>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <!-- Floating Active Mode Alert Message -->
  <div class="floating-alert-toast" id="alert-toast">
    <span>💡 Hint: Use the <strong>Text Tool (T)</strong> to click & edit any text on the website! Changes revert in 10s.</span>
    <button class="toast-close-btn" id="toast-close">×</button>
  </div>
</div>

<style is:global>
  /* Override default scrolling on body to fit full-screen Figma Canvas on desktop */
  @media (min-width: 769px) {
    body, html {
      overflow: hidden !important;
      height: 100vh !important;
      width: 100vw !important;
      margin: 0 !important;
      padding: 0 !important;
      user-select: none; /* Prevents awkward dragging highlights on canvas components */
    }
  }

  /* Make sure portfolio interactive states play nicely with contenteditable */
  .figma-editing-text {
    outline: 2px dashed #18A0FB !important;
    outline-offset: 4px;
    background-color: rgba(24, 160, 251, 0.08) !important;
    border-radius: 4px;
    caret-color: #18A0FB !important;
    user-select: text !important;
  }

  /* 10s countdown revert tag */
  .figma-revert-badge {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #18A0FB;
    color: white;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 4px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.25);
    z-index: 9999;
    pointer-events: none;
    transform: translateY(-135%) translateX(10px);
    transition: transform 0.2s ease;
  }

  .revert-spinner {
    width: 14px;
    height: 14px;
    transform: rotate(-90deg);
  }

  .revert-spinner circle {
    fill: none;
    stroke-width: 2.5;
  }

  .revert-spinner circle.bg {
    stroke: rgba(255, 255, 255, 0.25);
  }

  .revert-spinner circle.progress {
    stroke: #ffffff;
    stroke-linecap: round;
  }

  /* Flash Highlight Animation after text reverts */
  @keyframes revertFlash {
    0% { background-color: rgba(10, 207, 131, 0.5); box-shadow: 0 0 15px rgba(10, 207, 131, 0.6); }
    100% { background-color: transparent; }
  }

  .figma-reverted-flash {
    animation: revertFlash 1s ease;
  }

  /* Custom Cursors depending on Figma tool selected */
  .figma-cursor-select {
    cursor: default !important;
  }

